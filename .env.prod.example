POSTGRES_DB=sdrf_studio
POSTGRES_USER=sdrf
POSTGRES_PASSWORD=change-this-long-random-password
DATABASE_URL=postgresql+psycopg://sdrf:change-this-long-random-password@db:5432/sdrf_studio
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/storage

# Public URL users open in the browser. Include every allowed origin here.
CORS_ORIGINS=https://sdrf.example.edu.cn

# Server-side AI proxy. Never put this key in the frontend.
ENABLE_CLOUD_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_CHAT_BASE_URL=https://api.openai.com/v1/chat/completions
AI_CHAT_TIMEOUT_SECONDS=120
